#include "fs_indexed.h"

/* 
Global file system instance.
This is the one actual file system used by the whole program.
*/
FileSystem fs;

/*
Helper function:
Given a file size in bytes, compute how many data blocks are needed.

Example:
- if size = 1 byte, need 1 block
- if size = 1024 bytes, need 1 block
- if size = 1025 bytes, need 2 blocks
*/
static int blocksNeeded(int size)
{
    /* Non-positive size means no data blocks are needed */
    if (size <= 0) {
        return 0;
    }

    /* Round up division */
    return (size + BLOCK_SIZE - 1) / BLOCK_SIZE;
}

/*
Helper function:
Clear the contents of a block by setting all bytes to 0.
This simulates erasing old data from that block.
*/
static void clearBlock(int blockNumber)
{
    /* Only clear if the block number is valid */
    if (blockNumber >= 0 && blockNumber < TOTAL_BLOCKS) {
        memset(fs.blocks[blockNumber].data, 0, BLOCK_SIZE);
    }
}

/*
Helper function:
Search for a file by name in the file table.

Returns:
- the array index of the file if found
- -1 if not found
*/
static int findFileIndex(const char *filename)
{
    int i;

    for (i = 0; i < MAX_FILES; i++) {
        /* File must be in use and names must match */
        if (fs.files[i].inUse && strcmp(fs.files[i].fileName, filename) == 0) {
            return i;
        }
    }

    return -1;
}

/*
Helper function:
Get an available File Information Block ID (FIB ID).

fibStatus[i] == 1 means available
fibStatus[i] == 0 means already in use

Returns:
- a valid FIB ID if one is available
- -1 if none are available
*/
static int getFileInformationBlockID(void)
{
    int i;

    for (i = 0; i < MAX_FILES; i++) {
        if (fs.fibStatus[i] == 1) {
            /* Mark this FIB ID as used */
            fs.fibStatus[i] = 0;
            return i;
        }
    }

    return -1;
}

/*
Helper function:
Return a FIB ID back to the pool of available FIB IDs.
*/
static void releaseFileInformationBlockID(int fibID)
{
    if (fibID >= 0 && fibID < MAX_FILES) {
        fs.fibStatus[fibID] = 1;
    }
}

/*
Utility function:
Allocate one free block from the head of the free block list.

Process:
1. Take the first node from the free list
2. Remove it from the linked list
3. Decrease free block count
4. Clear the block contents
5. Return the block number

Returns:
- block number if successful
- -1 if no free blocks exist
*/
int allocateFreeBlock(void)
{
    FreeBlockNode *temp;
    int blockNumber;

    /* No free blocks left */
    if (fs.freeHead == NULL) {
        return -1;
    }

    /* Remove node from head of free list */
    temp = fs.freeHead;
    blockNumber = temp->blockNumber;
    fs.freeHead = fs.freeHead->next;

    /* If list becomes empty, tail must also become NULL */
    if (fs.freeHead == NULL) {
        fs.freeTail = NULL;
    }

    /* Free the linked list node structure */
    free(temp);

    /* Update count of free blocks */
    fs.freeBlockCount--;

    /* Clear block contents before giving it out */
    clearBlock(blockNumber);

    return blockNumber;
}

/*
Utility function:
Return a block back to the tail of the free block list.

Process:
1. Create a new linked list node for this block
2. Add it to the end of the free list
3. Clear its contents
4. Increase free block count
*/
void returnFreeBlock(int blockNumber)
{
    FreeBlockNode *node;

    /* Ignore invalid block numbers */
    if (blockNumber < 0 || blockNumber >= TOTAL_BLOCKS) {
        return;
    }

    /* Create a new free-list node */
    node = (FreeBlockNode *)malloc(sizeof(FreeBlockNode));
    if (node == NULL) {
        printf("Error: could not return block %d to free list.\n", blockNumber);
        return;
    }

    /* Clear old data inside the block */
    clearBlock(blockNumber);

    node->blockNumber = blockNumber;
    node->next = NULL;

    /* If free list is empty, new node becomes both head and tail */
    if (fs.freeTail == NULL) {
        fs.freeHead = node;
        fs.freeTail = node;
    } else {
        /* Otherwise append to the end */
        fs.freeTail->next = node;
        fs.freeTail = node;
    }

    fs.freeBlockCount++;
}

/*
Initialize the entire file system.

This function:
1. Clears any old free-list nodes
2. Resets file system counters
3. Initializes all disk blocks
4. Marks all FIB IDs as available
5. Resets all file entries
6. Adds every block to the free block list
*/
void initFS(void)
{
    int i;
    FreeBlockNode *temp;

    /* Free any existing free-list nodes from a previous run */
    while (fs.freeHead != NULL) {
        temp = fs.freeHead;
        fs.freeHead = fs.freeHead->next;
        free(temp);
    }

    /* Reset linked-list pointers and counters */
    fs.freeHead = NULL;
    fs.freeTail = NULL;
    fs.fileCount = 0;
    fs.freeBlockCount = 0;

    /* Initialize all disk blocks */
    for (i = 0; i < TOTAL_BLOCKS; i++) {
        fs.blocks[i].blockNumber = i;
        memset(fs.blocks[i].data, 0, BLOCK_SIZE);
    }

    /* Initialize all FIB entries and mark them as free */
    for (i = 0; i < MAX_FILES; i++) {
        fs.fibStatus[i] = 1;              /* 1 means FIB is available */
        fs.files[i].fibID = i;
        fs.files[i].fileName[0] = '\0';
        fs.files[i].fileSize = 0;
        fs.files[i].blockCount = 0;
        fs.files[i].indexBlock = -1;
        fs.files[i].inUse = 0;
    }

    /* Put every block into the free block list */
    for (i = 0; i < TOTAL_BLOCKS; i++) {
        returnFreeBlock(i);
    }

    printf("File system initialized successfully. Total blocks created: %d\n", TOTAL_BLOCKS);
}

/*
Create a new file using indexed allocation.

Indexed allocation means:
- one block is used as the index block
- the index block stores the numbers of all data blocks used by the file

Process:
1. Validate filename and size
2. Check duplicate file name
3. Check file count limit
4. Compute number of data blocks needed
5. Check enough free blocks exist
6. Get a free FIB ID
7. Allocate one index block
8. Allocate needed data blocks
9. Store data block numbers inside the index block
10. Fill in the file's FIB metadata
*/
int createFile(const char *filename, int size)
{
    int fibID;
    int dataBlocks;
    int totalBlocksNeeded;
    int indexBlock;
    int *indexEntries;
    int allocated[MAX_INDEX_ENTRIES];
    int i;

    /* Validate filename */
    if (filename == NULL || strlen(filename) == 0 || strlen(filename) >= MAX_FILENAME_LEN) {
        printf("Error: invalid filename.\n");
        return 0;
    }

    /* File size cannot be negative */
    if (size < 0) {
        printf("Error: invalid file size.\n");
        return 0;
    }

    /* File names must be unique */
    if (findFileIndex(filename) != -1) {
        printf("Error: file '%s' already exists.\n", filename);
        return 0;
    }

    /* Cannot exceed maximum number of files */
    if (fs.fileCount >= MAX_FILES) {
        printf("Error: maximum number of files reached.\n");
        return 0;
    }

    /* Calculate required number of data blocks */
    dataBlocks = blocksNeeded(size);

    /* One index block can only hold a limited number of block pointers */
    if (dataBlocks > MAX_INDEX_ENTRIES) {
        printf("Error: file '%s' is too large for one index block.\n", filename);
        return 0;
    }

    /* Need 1 index block plus the data blocks */
    totalBlocksNeeded = dataBlocks + 1;

    /* Make sure enough free blocks exist */
    if (totalBlocksNeeded > fs.freeBlockCount) {
        printf("Error: not enough free blocks for '%s'.\n", filename);
        return 0;
    }

    /* Reserve a FIB ID for this file */
    fibID = getFileInformationBlockID();
    if (fibID == -1) {
        printf("Error: no free FIB ID available.\n");
        return 0;
    }

    /* Allocate the index block */
    indexBlock = allocateFreeBlock();
    if (indexBlock == -1) {
        releaseFileInformationBlockID(fibID);
        printf("Error: failed to allocate index block.\n");
        return 0;
    }

    /*
    Treat the raw bytes in the index block as an array of integers.
    Each integer will store one data block number.
    */
    indexEntries = (int *)fs.blocks[indexBlock].data;

    /* Initialize all index entries to -1 */
    for (i = 0; i < MAX_INDEX_ENTRIES; i++) {
        indexEntries[i] = -1;
    }

    /* Allocate all needed data blocks */
    for (i = 0; i < dataBlocks; i++) {
        allocated[i] = allocateFreeBlock();

        /* If allocation fails midway, clean up everything already allocated */
        if (allocated[i] == -1) {
            int j;

            for (j = 0; j < i; j++) {
                returnFreeBlock(allocated[j]);
            }

            returnFreeBlock(indexBlock);
            releaseFileInformationBlockID(fibID);

            printf("Error: failed to allocate data blocks.\n");
            return 0;
        }

        /* Store the allocated data block number inside the index block */
        indexEntries[i] = allocated[i];
    }

    /* Fill the file's metadata in its FIB */
    fs.files[fibID].fibID = fibID;
    strcpy(fs.files[fibID].fileName, filename);
    fs.files[fibID].fileSize = size;
    fs.files[fibID].blockCount = dataBlocks;
    fs.files[fibID].indexBlock = indexBlock;
    fs.files[fibID].inUse = 1;

    fs.fileCount++;

    printf("File '%s' created successfully.\n", filename);
    return 1;
}

/*
Delete a file from the file system.

Process:
1. Find the file by name
2. Read its index block
3. Return all its data blocks to the free list
4. Return the index block to the free list
5. Release the FIB ID
6. Clear the file's metadata
*/
int deleteFile(const char *filename)
{
    int fileIndex;
    int indexBlock;
    int *indexEntries;
    int i;

    /* Search for the file */
    fileIndex = findFileIndex(filename);
    if (fileIndex == -1) {
        printf("Error: file '%s' not found.\n", filename);
        return 0;
    }

    /* Get the file's index block */
    indexBlock = fs.files[fileIndex].indexBlock;

    /* Read the block numbers stored in the index block */
    indexEntries = (int *)fs.blocks[indexBlock].data;

    /* Return each data block used by the file */
    for (i = 0; i < fs.files[fileIndex].blockCount; i++) {
        if (indexEntries[i] != -1) {
            returnFreeBlock(indexEntries[i]);
        }
    }

    /* Return the index block itself */
    returnFreeBlock(indexBlock);

    /* Release the FIB ID so it can be reused */
    releaseFileInformationBlockID(fs.files[fileIndex].fibID);

    /* Clear the file's FIB entry */
    fs.files[fileIndex].fileName[0] = '\0';
    fs.files[fileIndex].fileSize = 0;
    fs.files[fileIndex].blockCount = 0;
    fs.files[fileIndex].indexBlock = -1;
    fs.files[fileIndex].inUse = 0;

    fs.fileCount--;

    printf("File '%s' deleted successfully.\n", filename);
    return 1;
}

/*
Display all files currently stored in the root directory.
Shows:
- file name
- file size in bytes
- number of data blocks
- FIB ID
*/
void listFiles(void)
{
    int i;

    printf("Root Directory Listing (%d files):\n", fs.fileCount);

    for (i = 0; i < MAX_FILES; i++) {
        if (fs.files[i].inUse) {
            printf("%-10s | %4d bytes | %d data blocks | FIBID=%d\n",
                   fs.files[i].fileName,
                   fs.files[i].fileSize,
                   fs.files[i].blockCount,
                   fs.files[i].fibID);
        }
    }
}

/*
Print the current free block list from head to tail.
Also count how many free blocks are currently available.
*/
void printFreeBlocks(void)
{
    FreeBlockNode *current = fs.freeHead;
    int count = 0;

    printf("Free block list: ");

    while (current != NULL) {
        printf("%d ", current->blockNumber);
        current = current->next;
        count++;
    }

    printf("\nTotal free blocks: %d\n", count);
}

/*
Destroy the file system's free block linked list.

This mainly frees dynamically allocated linked-list nodes.
It also resets the basic counters and pointers.
*/
void destroyFS(void)
{
    FreeBlockNode *temp;

    while (fs.freeHead != NULL) {
        temp = fs.freeHead;
        fs.freeHead = fs.freeHead->next;
        free(temp);
    }

    fs.freeTail = NULL;
    fs.fileCount = 0;
    fs.freeBlockCount = 0;
}